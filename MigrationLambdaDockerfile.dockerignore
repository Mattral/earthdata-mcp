# Ignore everything by default
*

# lambdas/migration/requirements.txt, lambdas/migration/handler.py
!lambdas/
lambdas/*
!lambdas/migration/

# migrations/
!migrations/

# util/database.py, util/secrets.py, util/__init__.py
!util/
util/*
!util/database.py
!util/secrets.py
!util/__init__.py

# Exclude artifacts from allowed dirs
**/__pycache__
**/*.pyc
**/*.pyo
**/.pytest_cache
