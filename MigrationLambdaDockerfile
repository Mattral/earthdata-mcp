FROM public.ecr.aws/lambda/python:3.13

# System dependencies for psycopg (PostgreSQL client)
RUN dnf install -y postgresql15-devel gcc python3-devel && \
    dnf clean all

COPY lambdas/migration/requirements.txt ${LAMBDA_TASK_ROOT}/
RUN pip install --no-cache-dir -r requirements.txt

COPY lambdas/migration/handler.py ${LAMBDA_TASK_ROOT}/
COPY migrations/ ${LAMBDA_TASK_ROOT}/migrations/
COPY util/database.py ${LAMBDA_TASK_ROOT}/util/database.py
COPY util/secrets.py ${LAMBDA_TASK_ROOT}/util/secrets.py
COPY util/__init__.py ${LAMBDA_TASK_ROOT}/util/__init__.py

CMD ["handler.handler"]
