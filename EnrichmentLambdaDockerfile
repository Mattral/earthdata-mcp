FROM public.ecr.aws/lambda/python:3.13

COPY lambdas/enrichment/requirements.txt ${LAMBDA_TASK_ROOT}/
RUN pip install --no-cache-dir -r requirements.txt

COPY lambdas/__init__.py ${LAMBDA_TASK_ROOT}/lambdas/
COPY lambdas/enrichment/ ${LAMBDA_TASK_ROOT}/lambdas/enrichment/
COPY models/ ${LAMBDA_TASK_ROOT}/models/
COPY util/ ${LAMBDA_TASK_ROOT}/util/

CMD ["lambdas.enrichment.handler.handler"]
